<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jeecg.modules.content.mapper.ContentMediaRelationMapper">

    <!-- 根据内容ID查询关联的媒体文件 -->
    <select id="selectByContentId" parameterType="java.lang.String" resultType="org.jeecg.modules.content.entity.ContentMediaRelationEntity">
        SELECT * FROM content_media_relations 
        WHERE content_id = #{contentId} 
        ORDER BY sort_order ASC, create_time ASC
    </select>

    <!-- 根据媒体ID查询关联的内容 -->
    <select id="selectByMediaId" parameterType="java.lang.String" resultType="org.jeecg.modules.content.entity.ContentMediaRelationEntity">
        SELECT * FROM content_media_relations 
        WHERE media_id = #{mediaId} 
        ORDER BY create_time DESC
    </select>

    <!-- 根据内容ID和关联类型查询媒体文件 -->
    <select id="selectByContentIdAndType" resultType="org.jeecg.modules.content.entity.ContentMediaRelationEntity">
        SELECT * FROM content_media_relations 
        WHERE content_id = #{contentId} AND relation_type = #{relationType} 
        ORDER BY sort_order ASC, create_time ASC
    </select>

    <!-- 根据内容ID删除所有关联 -->
    <delete id="deleteByContentId" parameterType="java.lang.String">
        DELETE FROM content_media_relations WHERE content_id = #{contentId}
    </delete>

    <!-- 根据媒体ID删除所有关联 -->
    <delete id="deleteByMediaId" parameterType="java.lang.String">
        DELETE FROM content_media_relations WHERE media_id = #{mediaId}
    </delete>

    <!-- 根据内容ID和关联类型删除关联 -->
    <delete id="deleteByContentIdAndType">
        DELETE FROM content_media_relations 
        WHERE content_id = #{contentId} AND relation_type = #{relationType}
    </delete>

    <!-- 批量插入关联记录 -->
    <insert id="batchInsert">
        INSERT INTO content_media_relations (id, content_id, media_id, relation_type, sort_order, position_data, create_time)
        VALUES
        <foreach collection="relations" item="item" separator=",">
            (#{item.id}, #{item.contentId}, #{item.mediaId}, #{item.relationType}, #{item.sortOrder}, #{item.positionData}, #{item.createTime})
        </foreach>
    </insert>

    <!-- 更新关联记录的排序 -->
    <update id="updateSortOrder">
        UPDATE content_media_relations 
        SET sort_order = #{sortOrder} 
        WHERE id = #{id}
    </update>

    <!-- 批量更新排序 -->
    <update id="batchUpdateSortOrder">
        <foreach collection="relations" item="item" separator=";">
            UPDATE content_media_relations 
            SET sort_order = #{item.sortOrder} 
            WHERE id = #{item.id}
        </foreach>
    </update>

    <!-- 查询内容的封面图片 -->
    <select id="selectCoverByContentId" parameterType="java.lang.String" resultType="org.jeecg.modules.content.entity.MediaFileEntity">
        SELECT mf.* FROM media_files mf 
        INNER JOIN content_media_relations cmr ON mf.id = cmr.media_id 
        WHERE cmr.content_id = #{contentId} AND cmr.relation_type = 'cover' 
        AND mf.deleted = 0 
        ORDER BY cmr.sort_order ASC, cmr.create_time ASC LIMIT 1
    </select>

    <!-- 媒体文件详细信息结果映射 -->
    <resultMap id="MediaFileWithRelationMap" type="org.jeecg.modules.content.entity.MediaFileEntity">
        <id property="id" column="id"/>
        <result property="fileName" column="file_name"/>
        <result property="fileUrl" column="file_url"/>
        <result property="fileSize" column="file_size"/>
        <result property="fileType" column="file_type"/>
        <result property="mimeType" column="mime_type"/>
        <result property="width" column="width"/>
        <result property="height" column="height"/>
        <result property="duration" column="duration"/>
        <result property="resolution" column="resolution"/>
        <result property="bitrate" column="bitrate"/>
        <result property="storageType" column="storage_type"/>
        <result property="storagePath" column="storage_path"/>
        <result property="cdnUrl" column="cdn_url"/>
        <result property="status" column="status"/>
        <result property="processStatus" column="process_status"/>
        <result property="metadata" column="metadata"/>
        <result property="uploaderId" column="uploader_id"/>
        <result property="uploadTime" column="upload_time"/>
        <result property="deleted" column="deleted"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="relationType" column="relation_type"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="positionData" column="position_data"/>
    </resultMap>

    <!-- 查询内容关联的所有媒体文件（带详细信息） -->
    <select id="selectMediaFilesByContentId" parameterType="java.lang.String" resultMap="MediaFileWithRelationMap">
        SELECT mf.*, cmr.relation_type, cmr.sort_order, cmr.position_data 
        FROM media_files mf 
        INNER JOIN content_media_relations cmr ON mf.id = cmr.media_id 
        WHERE cmr.content_id = #{contentId} AND mf.deleted = 0 
        ORDER BY cmr.sort_order ASC, cmr.create_time ASC
    </select>

    <!-- 统计媒体文件的使用次数 -->
    <select id="countUsageByMediaId" parameterType="java.lang.String" resultType="java.lang.Long">
        SELECT COUNT(*) FROM content_media_relations WHERE media_id = #{mediaId}
    </select>

    <!-- 查询未被使用的媒体文件ID列表 -->
    <select id="selectUnusedMediaIds" resultType="java.lang.String">
        SELECT mf.id FROM media_files mf 
        LEFT JOIN content_media_relations cmr ON mf.id = cmr.media_id 
        WHERE cmr.media_id IS NULL AND mf.deleted = 0
    </select>

    <!-- 查询指定关联类型的媒体文件数量 -->
    <select id="countByContentIdAndType" resultType="java.lang.Long">
        SELECT COUNT(*) FROM content_media_relations 
        WHERE content_id = #{contentId} AND relation_type = #{relationType}
    </select>

</mapper>