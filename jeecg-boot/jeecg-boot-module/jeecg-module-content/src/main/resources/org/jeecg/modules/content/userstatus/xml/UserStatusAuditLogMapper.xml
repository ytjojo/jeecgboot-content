<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jeecg.modules.content.userstatus.mapper.UserStatusAuditLogMapper">

    <resultMap id="BaseResultMap" type="org.jeecg.modules.content.userstatus.entity.UserStatusAuditLog">
        <id column="log_id" property="logId"/>
        <result column="user_id" property="userId"/>
        <result column="from_status" property="fromStatus"/>
        <result column="to_status" property="toStatus"/>
        <result column="operator_id" property="operatorId"/>
        <result column="operator_type" property="operatorType"/>
        <result column="trigger_reason" property="triggerReason"/>
        <result column="rule_id" property="ruleId"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="remark" property="remark"/>
        <result column="ip_address" property="ipAddress"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="selectByUserId" parameterType="String" resultMap="BaseResultMap">
        SELECT * FROM content_user_status_audit_log
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>

    <select id="selectByUserIdAndTimeRange" resultMap="BaseResultMap">
        SELECT * FROM content_user_status_audit_log
        WHERE user_id = #{userId}
        AND created_at BETWEEN #{startTime} AND #{endTime}
        ORDER BY created_at DESC
    </select>

</mapper>
