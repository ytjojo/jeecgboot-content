<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jeecg.modules.content.mapper.ContentTagRelationMapper">

    <!-- =============================================
         内容标签关联查询相关方法
         ============================================= -->

    <!-- 根据内容ID查询关联的标签 -->
    <select id="selectByContentId" parameterType="java.lang.String" resultType="org.jeecg.modules.content.entity.ContentTagRelationEntity">
        SELECT * FROM content_tag_relations 
        WHERE content_id = #{contentId} 
        ORDER BY create_time ASC
    </select>

    <!-- 根据标签ID查询关联的内容 -->
    <select id="selectByTagId" parameterType="java.lang.String" resultType="org.jeecg.modules.content.entity.ContentTagRelationEntity">
        SELECT * FROM content_tag_relations 
        WHERE tag_id = #{tagId} 
        ORDER BY create_time DESC
    </select>

    <!-- 根据内容ID和标签ID查询关联记录 -->
    <select id="selectByContentIdAndTagId" resultType="org.jeecg.modules.content.entity.ContentTagRelationEntity">
        SELECT * FROM content_tag_relations 
        WHERE content_id = #{contentId} AND tag_id = #{tagId}
        LIMIT 1
    </select>

    <!-- 根据内容ID列表查询所有标签关联 -->
    <select id="selectByContentIds" resultType="org.jeecg.modules.content.entity.ContentTagRelationEntity">
        SELECT * FROM content_tag_relations 
        WHERE content_id IN 
        <foreach collection="contentIds" item="contentId" open="(" separator="," close=")">
            #{contentId}
        </foreach>
        ORDER BY content_id, create_time ASC
    </select>

    <!-- 根据标签ID列表查询所有内容关联 -->
    <select id="selectByTagIds" resultType="org.jeecg.modules.content.entity.ContentTagRelationEntity">
        SELECT * FROM content_tag_relations 
        WHERE tag_id IN 
        <foreach collection="tagIds" item="tagId" open="(" separator="," close=")">
            #{tagId}
        </foreach>
        ORDER BY tag_id, create_time DESC
    </select>

    <!-- =============================================
         内容标签关联删除相关方法
         ============================================= -->

    <!-- 根据内容ID删除所有标签关联 -->
    <delete id="deleteByContentId" parameterType="java.lang.String">
        DELETE FROM content_tag_relations WHERE content_id = #{contentId}
    </delete>

    <!-- 根据标签ID删除所有内容关联 -->
    <delete id="deleteByTagId" parameterType="java.lang.String">
        DELETE FROM content_tag_relations WHERE tag_id = #{tagId}
    </delete>

    <!-- =============================================
         内容标签关联批量操作相关方法
         ============================================= -->

    <!-- 批量插入内容标签关联 -->
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO content_tag_relations (id, content_id, tag_id, create_by, create_time)
        VALUES
        <foreach collection="relations" item="relation" separator=",">
            (#{relation.id}, #{relation.contentId}, #{relation.tagId}, #{relation.createBy}, #{relation.createTime})
        </foreach>
    </insert>

    <!-- =============================================
         内容标签关联统计相关方法
         ============================================= -->

    <!-- 统计标签的使用次数 -->
    <select id="countByTagId" parameterType="java.lang.String" resultType="java.lang.Long">
        SELECT COUNT(*) FROM content_tag_relations WHERE tag_id = #{tagId}
    </select>

    <!-- 统计内容的标签数量 -->
    <select id="countByContentId" parameterType="java.lang.String" resultType="java.lang.Long">
        SELECT COUNT(*) FROM content_tag_relations WHERE content_id = #{contentId}
    </select>

    <!-- =============================================
         内容标签关联ID查询相关方法
         ============================================= -->

    <!-- 查询内容的标签ID列表 -->
    <select id="selectTagIdsByContentId" parameterType="java.lang.String" resultType="java.lang.String">
        SELECT tag_id FROM content_tag_relations 
        WHERE content_id = #{contentId} 
        ORDER BY create_time ASC
    </select>

    <!-- 查询标签的内容ID列表 -->
    <select id="selectContentIdsByTagId" parameterType="java.lang.String" resultType="java.lang.String">
        SELECT content_id FROM content_tag_relations 
        WHERE tag_id = #{tagId} 
        ORDER BY create_time DESC
    </select>

</mapper>