<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jeecg.modules.content.circle.mapper.CircleReportMapper">

    <resultMap id="BaseResultMap" type="org.jeecg.modules.content.circle.entity.CircleReport">
        <id column="id" property="id"/>
        <result column="circle_id" property="circleId"/>
        <result column="content_id" property="contentId"/>
        <result column="reporter_id" property="reporterId"/>
        <result column="reason" property="reason"/>
        <result column="status" property="status"/>
        <result column="operator_id" property="operatorId"/>
        <result column="operate_time" property="operateTime"/>
        <result column="handle_action" property="handleAction"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByCircleAndStatus" resultMap="BaseResultMap">
        SELECT * FROM circle_report
        WHERE circle_id = #{circleId}
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
