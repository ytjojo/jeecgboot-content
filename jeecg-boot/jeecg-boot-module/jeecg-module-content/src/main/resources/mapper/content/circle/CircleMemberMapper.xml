<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jeecg.modules.content.circle.mapper.CircleMemberMapper">

    <select id="selectMemberUserIds" resultType="java.lang.String">
        SELECT user_id FROM circle_member
        WHERE circle_id = #{circleId} AND status = 'ACTIVE'
    </select>

</mapper>
