<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jeecg.modules.content.circle.mapper.CircleContentMapper">

    <resultMap id="BaseResultMap" type="org.jeecg.modules.content.circle.entity.CircleContent">
        <id column="id" property="id"/>
        <result column="circle_id" property="circleId"/>
        <result column="user_id" property="userId"/>
        <result column="content" property="content"/>
        <result column="content_type" property="contentType"/>
        <result column="status" property="status"/>
        <result column="is_pinned" property="isPinned"/>
        <result column="pinned_at" property="pinnedAt"/>
        <result column="is_featured" property="isFeatured"/>
        <result column="featured_at" property="featuredAt"/>
        <result column="deleted" property="deleted"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectCircleContentList" resultMap="BaseResultMap">
        SELECT * FROM circle_content
        WHERE circle_id = #{circleId} AND deleted = 0
        ORDER BY is_pinned DESC, pinned_at DESC, create_time DESC
        LIMIT 500
    </select>

    <select id="selectPostStatsGroupByCircle" resultType="java.util.Map">
        SELECT circle_id,
               SUM(CASE WHEN content_type = 'POST' AND deleted = 0 THEN 1 ELSE 0 END) AS post_count,
               SUM(CASE WHEN create_time >= #{todayStart} AND content_type = 'POST' AND deleted = 0 THEN 1 ELSE 0 END) AS new_post_count
        FROM circle_content
        WHERE deleted = 0
        GROUP BY circle_id
    </select>

    <select id="selectActiveUserStatsGroupByCircle" resultType="java.util.Map">
        SELECT circle_id,
               COUNT(DISTINCT user_id) AS active_count
        FROM circle_content
        WHERE deleted = 0 AND create_time >= #{thirtyDaysAgo}
        GROUP BY circle_id
    </select>

</mapper>
